# Скопируйте рядом с этим файлом как keystore.properties и заполните.
# Файл keystore.properties в git не попадает (.gitignore).

storePassword=ВАШ_STORE_PASSWORD
keyPassword=ВАШ_KEY_PASSWORD
keyAlias=ВАШ_ALIAS
# Путь относительно папки android/ (рядом с app/, build.gradle корня Android)
storeFile=my-upload-key.keystore
